[{"name":"البنا الإسلامي","developer":"Ahmed Elbanna","version":"1.4","description":"العنوان: تطبيق \"البنا الإسلامي\" – الأناقة تلتقي بالعبادة.\n​\"استمتع بتجربة إيمانية فريدة مع تطبيق البنا الإسلامي. \nصُمم هذا التطبيق خصيصاً للمستخدم العربي الذي يبحث عن الجمال والدقة في آن واحد. بلمسات ذهبية وواجهة مستخدم عصرية، يوفر لك التطبيق كل ما تحتاجه في يومك: من تلاوات خاشعة بصوت الشيخ المنشاوي، ومواقيت صلاة دقيقة، إلى رقية شرعية وسبحة إلكترونية متطورة. 'البنا الإسلامي' ليس مجرد تطبيق، بل هو رفيقك الرقمي الذي ينبض بالحياة.\"","icon":"data:image/jpeg;base64,","code":"<!DOCTYPE html>\n<html lang=\"ar\" dir=\"rtl\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>البنا الإسلامي - Horus Edition</title>\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n    <link href=\"https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root { \n            --gold: #f7c873; \n            --dark: #0a2621; \n            --glass: rgba(255, 255, 255, 0.07);\n            --bg-gradient: linear-gradient(135deg, #1a5f4b 0%, #051412 100%);\n            --text-color: #f0f3f5;\n        }\n\n        body.night-mode {\n            --bg-gradient: linear-gradient(135deg, #000000 0%, #0a0a0a 100%);\n            --text-color: var(--gold);\n            --glass: rgba(247, 200, 115, 0.05);\n        }\n\n        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Tajawal', sans-serif; transition: background 0.3s, color 0.3s; }\n        body { background: var(--bg-gradient); color: var(--text-color); padding: 15px; min-height: 100vh; }\n        \n        .app-container { max-width: 500px; margin: 0 auto; background: var(--glass); backdrop-filter: blur(20px); border-radius: 40px; border: 1px solid rgba(247, 200, 115, 0.2); min-height: 95vh; display: flex; flex-direction: column; overflow: hidden; position: relative; }\n\n        .app-header { padding: 20px; text-align: center; border-bottom: 1px solid rgba(247, 200, 115, 0.1); position: relative; }\n        .mode-toggle { position: absolute; left: 20px; top: 20px; color: var(--gold); cursor: pointer; font-size: 20px; }\n        \n        .date-container { display: flex; justify-content: center; gap: 8px; margin-bottom: 12px; font-size: 12px; }\n        .date-box { background: rgba(0,0,0,0.3); padding: 5px 12px; border-radius: 50px; border: 1px solid var(--gold); color: var(--gold); }\n        .logo-area i { font-size: 35px; color: var(--gold); }\n        \n        .content-screen { display: none; padding: 15px; flex-direction: column; height: 100%; overflow-y: auto; }\n        .content-screen.active { display: flex; }\n\n        .daily-card { background: rgba(0,0,0,0.2); padding: 15px; border-radius: 20px; margin-bottom: 10px; border-right: 4px solid var(--gold); color: inherit; position: relative; }\n        .daily-card h3 { color: var(--gold); font-size: 15px; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }\n\n        .menu-list { display: flex; flex-direction: column; gap: 10px; padding: 10px 0; }\n        .menu-item { background: rgba(42, 95, 81, 0.4); padding: 18px; border-radius: 20px; display: flex; align-items: center; gap: 15px; cursor: pointer; border: 1px solid rgba(247, 200, 115, 0.1); color: inherit; }\n        .menu-item i { font-size: 22px; color: var(--gold); width: 30px; text-align: center; }\n\n        .player-fixed { position: sticky; top: 0; background: #071d1a; padding: 15px; border-radius: 20px; border: 1px solid var(--gold); z-index: 100; margin-bottom: 15px; }\n        body.night-mode .player-fixed { background: #000; }\n        .player-controls { display: flex; justify-content: center; gap: 25px; align-items: center; margin-top: 10px; }\n        .control-btn { cursor: pointer; color: var(--gold); font-size: 18px; }\n        .control-btn.active { color: #fff; text-shadow: 0 0 8px var(--gold); }\n        \n        .search-box { background: rgba(0,0,0,0.3); border: 1px solid var(--gold); border-radius: 50px; padding: 10px 20px; color: var(--gold); width: 100%; margin-bottom: 10px; outline: none; }\n        .sura-card { background: rgba(0,0,0,0.2); padding: 12px; border-radius: 12px; display: flex; justify-content: space-between; margin-bottom: 8px; cursor: pointer; border-right: 3px solid var(--gold); color: inherit; }\n        .sura-card.playing { background: rgba(247, 200, 115, 0.2); border-left: 2px solid var(--gold); }\n        \n        .back-btn { background: rgba(0,0,0,0.3); border: 1px solid var(--gold); color: var(--gold); padding: 8px 20px; border-radius: 50px; cursor: pointer; width: fit-content; margin-bottom: 15px; }\n\n        .ruqya-text { line-height: 1.8; font-size: 16px; margin-bottom: 15px; text-align: justify; }\n        .section-title { color: var(--gold); border-bottom: 1px solid var(--gold); margin: 15px 0; padding-bottom: 5px; font-weight: bold; display: flex; align-items: center; gap: 10px; }\n\n        .prayer-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }\n        .city-title { color: var(--gold); border-bottom: 1px solid var(--gold); padding-bottom: 5px; margin-bottom: 10px; font-size: 18px; text-align: center; grid-column: span 2; }\n        .prayer-item { background: rgba(0,0,0,0.2); padding: 10px; border-radius: 12px; text-align: center; border: 1px solid rgba(247, 200, 115, 0.1); }\n        .prayer-name { font-size: 12px; opacity: 0.8; display: block; }\n        .prayer-time { font-size: 16px; font-weight: bold; color: var(--gold); }\n\n        .counter-area { display: flex; justify-content: space-between; align-items: center; margin-top: 10px; border-top: 1px solid rgba(247, 200, 115, 0.1); padding-top: 10px; }\n        \n        .progress-bar-container { background: rgba(247, 200, 115, 0.1); height: 8px; border-radius: 10px; overflow: hidden; margin-bottom: 10px; }\n        .progress-bar-fill { height: 100%; background: var(--gold); width: 0%; transition: width 0.3s; }\n        \n        .whatsapp-btn { display: flex; align-items: center; justify-content: center; gap: 10px; background: #25d366; color: white; padding: 12px; border-radius: 50px; text-decoration: none; font-weight: bold; margin-top: 20px; transition: 0.3s; }\n        .whatsapp-btn:hover { transform: scale(1.05); }\n\n        .content-screen::-webkit-scrollbar { width: 5px; }\n        .content-screen::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 10px; }\n\n        .reset-all-btn { background: rgba(255, 68, 68, 0.2); border: 1px solid #ff4444; color: #ff4444; padding: 5px 12px; border-radius: 50px; font-size: 12px; cursor: pointer; transition: 0.3s; }\n        .reset-all-btn:hover { background: #ff4444; color: #fff; }\n        .screen-header-flex { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; padding: 0 5px; }\n    </style>\n</head>\n<body>\n\n<div class=\"app-container\">\n    <div id=\"homeScreen\" class=\"content-screen active\">\n        <div class=\"app-header\">\n            <div class=\"mode-toggle\" onclick=\"toggleNightMode()\"><i id=\"modeIcon\" class=\"fas fa-moon\"></i></div>\n            <div class=\"date-container\">\n                <div class=\"date-box\" id=\"hijri\">-- هجري --</div>\n                <div class=\"date-box\" id=\"gregorian\">-- ميلادي --</div>\n            </div>\n            <div class=\"logo-area\"><i class=\"fas fa-mosque\"></i><h1 style=\"color:var(--gold); font-size:22px;\">البنا الإسلامي</h1></div>\n        </div>\n\n        <div class=\"daily-card\">\n            <h3><i class=\"fas fa-book-open\"></i> آية اليوم</h3>\n            <p id=\"ayah\" class=\"daily-content\">جاري التحميل...</p>\n        </div>\n\n        <div class=\"daily-card\">\n            <h3><i class=\"fas fa-heart\"></i> حديث اليوم</h3>\n            <p id=\"hadith\" class=\"daily-content\">جاري التحميل...</p>\n        </div>\n\n        <div class=\"menu-list\">\n            <div class=\"menu-item\" onclick=\"openScreen('morningAzkarScreen')\"><i class=\"fas fa-sun\"></i><span>أذكار الصباح</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('eveningAzkarScreen')\"><i class=\"fas fa-moon\"></i><span>أذكار المساء</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('quranScreen')\"><i class=\"fas fa-book-quran\"></i><span>القرآن الكريم (المنشاوي)</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('afterPrayerScreen')\"><i class=\"fas fa-pray\"></i><span>أذكار بعد الصلاة</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('sebhaScreen')\"><i class=\"fas fa-circle-nodes\"></i><span>السبحة</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('prayerScreen')\"><i class=\"fas fa-clock\"></i><span>مواقيت الصلاة</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('ruqyaScreen')\"><i class=\"fas fa-hand-sparkles\"></i><span>الرُّقية الشرعية</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('namesScreen')\"><i class=\"fas fa-star-and-crescent\"></i><span>أسماء الله الحسنى</span></div>\n            <div class=\"menu-item\" onclick=\"openScreen('aboutScreen')\"><i class=\"fas fa-user-gear\"></i><span>عن المبرمج</span></div>\n        </div>\n    </div>\n\n    <div id=\"morningAzkarScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div class=\"screen-header-flex\">\n            <h2 style=\"color:var(--gold);\"><i class=\"fas fa-sun\"></i> أذكار الصباح</h2>\n            <button class=\"reset-all-btn\" onclick=\"resetAllCountersInScreen('morningAzkarList')\">تصفير الكل</button>\n        </div>\n        <div id=\"morningAzkarList\" style=\"display: flex; flex-direction: column; gap: 15px; padding-bottom: 30px;\"></div>\n    </div>\n\n    <div id=\"eveningAzkarScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div class=\"screen-header-flex\">\n            <h2 style=\"color:var(--gold);\"><i class=\"fas fa-moon\"></i> أذكار المساء</h2>\n            <button class=\"reset-all-btn\" onclick=\"resetAllCountersInScreen('eveningAzkarList')\">تصفير الكل</button>\n        </div>\n        <div id=\"eveningAzkarList\" style=\"display: flex; flex-direction: column; gap: 15px; padding-bottom: 30px;\"></div>\n    </div>\n\n    <div id=\"quranScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div class=\"player-fixed\">\n            <p id=\"nowPlaying\" style=\"text-align:center; font-size:12px; color:var(--gold); margin-bottom:5px;\">اختر سورة</p>\n            <audio id=\"mainAudio\" controls style=\"width:100%; filter: sepia(1);\"><source id=\"audioSrc\" src=\"\"></audio>\n            <div class=\"player-controls\">\n                <i class=\"fas fa-step-forward control-btn\" onclick=\"playPrev()\"></i>\n                <i id=\"repeatBtn\" class=\"fas fa-redo control-btn\" onclick=\"toggleRepeat()\"></i>\n                <i class=\"fas fa-step-backward control-btn\" onclick=\"playNext()\"></i>\n            </div>\n        </div>\n        <input type=\"text\" id=\"suraSearch\" class=\"search-box\" placeholder=\"ابحث عن سورة...\" onkeyup=\"filterSuras()\">\n        <div id=\"suraIndex\"></div>\n    </div>\n\n    <div id=\"sebhaScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div class=\"screen-header-flex\">\n            <h2 style=\"color:var(--gold);\"><i class=\"fas fa-circle-nodes\"></i> السبحة</h2>\n            <button class=\"reset-all-btn\" onclick=\"resetAllCountersInScreen('azkarList')\">تصفير الكل</button>\n        </div>\n        <div id=\"azkarList\" style=\"display: flex; flex-direction: column; gap: 15px; padding-bottom: 30px;\"></div>\n    </div>\n\n    <div id=\"afterPrayerScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div class=\"screen-header-flex\">\n            <h2 style=\"color:var(--gold);\"><i class=\"fas fa-mosque\"></i> أذكار بعد الصلاة</h2>\n            <button class=\"reset-all-btn\" onclick=\"resetAllCountersInScreen('afterPrayerList')\">تصفير الكل</button>\n        </div>\n        <div id=\"afterPrayerList\" style=\"display: flex; flex-direction: column; gap: 15px; padding-bottom: 30px;\"></div>\n    </div>\n\n    <div id=\"ruqyaScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <h2 style=\"text-align:center; color:var(--gold);\"><i class=\"fas fa-hand-sparkles\"></i> الرقية الشرعية</h2>\n        <div class=\"section-title\"><i class=\"fas fa-book\"></i> من القرآن الكريم</div>\n        <div class=\"daily-card\"><p class=\"ruqya-text\"><b>سورة الفاتحة:</b><br>بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيمِ (1) الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ (2) الرَّحْمَنِ الرَّحِيمِ (3) مَالِكِ يَوْمِ الدِّينِ (4) إِيَّاكَ نَعْبُدُ وَإِيَّاكَ نَسْتَعِينُ (5) اهْدِنَا الصِّرَاطَ الْمُسْتَقِيمَ (6) صِرَاطَ الَّذِينَ أَنْعَمْتَ عَلَيْهِمْ غَيْرِ الْمَغْضُوبِ عَلَيْهِمْ وَلَا الضَّالِّينَ (7)</p></div>\n        <div class=\"daily-card\"><p class=\"ruqya-text\"><b>آية الكرسي:</b><br>اللَّهُ لَا إِلَهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ لَهُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ مَنْ ذَا الَّذِي يَشْفَعُ عِنْدَهُ إِلَّا بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يُحِيطُونَ بِشَيْءٍ مِنْ عِلْمِهِ إِلَّا بِمَا شَاءَ وَسِعَ كُرْسِيُّهُ السَّمَاوَاتِ وَالْأَرْضَ وَلَا يَئُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ</p></div>\n        <div class=\"daily-card\" onclick=\"updateCounter('countEkhlas', 3)\">\n            <p class=\"ruqya-text\"><b>سورة الإخلاص:</b><br>قُلْ هُوَ اللَّهُ أَحَدٌ (1) اللَّهُ الصَّمَدُ (2) لَمْ يَلِدْ وَلَمْ يُولَدْ (3) وَلَمْ يَكُن لَّهُ كُفُوًا أَحَدٌ (4)</p>\n            <div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"countEkhlas\">0</span> / 3</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer\" onclick=\"event.stopPropagation(); resetCounter('countEkhlas')\"></i></div>\n        </div>\n        <div class=\"daily-card\" onclick=\"updateCounter('countFalaq', 3)\">\n            <p class=\"ruqya-text\"><b>سورة الفلق:</b><br>قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ (1) مِن شَرِّ مَا خَلَقَ (2) وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ (3) وَمِن شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ (4) وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ (5)</p>\n            <div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"countFalaq\">0</span> / 3</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer\" onclick=\"event.stopPropagation(); resetCounter('countFalaq')\"></i></div>\n        </div>\n        <div class=\"daily-card\" onclick=\"updateCounter('countNas', 3)\">\n            <p class=\"ruqya-text\"><b>سورة الناس:</b><br>قُلْ أَعُوذُ بِرَبِّ النَّاسِ (1) مَلِكِ النَّاسِ (2) إِلَهِ النَّاسِ (3) مِن شَرِّ الْوَسْوااسِ الْخَنَّاسِ (4) الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ (5) مِنَ الْجِنَّةِ وَالنَّاسِ (6)</p>\n            <div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"countNas\">0</span> / 3</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer\" onclick=\"event.stopPropagation(); resetCounter('countNas')\"></i></div>\n        </div>\n        <div class=\"section-title\"><i class=\"fas fa-comment-dots\"></i> من السنة النبوية</div>\n        <div class=\"daily-card\" onclick=\"updateCounter('countTamat', 3)\">\n            <p class=\"ruqya-text\">أعوذ بكلمات الله التامات من شر ما خلق.</p>\n            <div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"countTamat\">0</span> / 3</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer\" onclick=\"event.stopPropagation(); resetCounter('countTamat')\"></i></div>\n        </div>\n        <div class=\"daily-card\" onclick=\"updateCounter('countBismillah', 3)\">\n            <p class=\"ruqya-text\">باسم الله الذي لا يضر مع اسمه شيء في الأرض ولا في السماء وهو السميع العليم.</p>\n            <div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"countBismillah\">0</span> / 3</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer\" onclick=\"event.stopPropagation(); resetCounter('countBismillah')\"></i></div>\n        </div>\n    </div>\n\n    <div id=\"prayerScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div id=\"prayerData\"><p style=\"text-align:center;\">جاري تحميل المواقيت...</p></div>\n    </div>\n\n    <div id=\"namesScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div id=\"namesData\" style=\"display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px;\"></div>\n    </div>\n\n    <div id=\"aboutScreen\" class=\"content-screen\">\n        <button class=\"back-btn\" onclick=\"goHome()\">رجوع</button>\n        <div class=\"daily-card\" style=\"text-align:center; padding: 30px 20px;\">\n            <i class=\"fas fa-code fa-4x\" style=\"color:var(--gold); margin-bottom:15px;\"></i>\n            <h2 style=\"color:var(--gold); margin-bottom:15px;\">أحمد عصام البنا</h2>\n            <p style=\"line-height:1.8; text-align: justify; font-size: 15px;\">\n                مبرمج التفاصيل وصانع التجارب الرقمية. بخبرة تدمج بين منطق البرمجة الصارم وفلسفة التصميم الراقي، يسعى المبرمج أحمد لوضع بصمة فريدة في عالم التطبيقات، محولاً الأكواد الجامدة إلى أدوات تنبض بالحياة والجمال.\n                <br><br>\n                \"إصدار سلسلة تطبيقات البنا\" ليس هي مجرد أكواد مكتوبة فقط، بل هو تجسيد لرؤية المبرمج أحمد في تقديم تكنولوجيا تليق بالمستخدم العربي.\n            </p>\n            \n            <a href=\"https://wa.me/201206781443\" target=\"_blank\" class=\"whatsapp-btn\">\n                <i class=\"fab fa-whatsapp\"></i> تواصل مع المبرمج\n            </a>\n        </div>\n    </div>\n</div>\n\n<script>\n    const suras = [\"الفاتحة\",\"البقرة\",\"آل عمران\",\"النساء\",\"المائدة\",\"الأنعام\",\"الأعراف\",\"الأنفال\",\"التوبة\",\"يونس\",\"هود\",\"يوسف\",\"الرعد\",\"إبراهيم\",\"الحجر\",\"النحل\",\"الإسراء\",\"الكهف\",\"مريم\",\"طه\",\"الأنبياء\",\"الحج\",\"المؤمنون\",\"النور\",\"الفرقان\",\"الشعراء\",\"النمل\",\"القصص\",\"العنكبوت\",\"الروم\",\"لقمان\",\"السجدة\",\"الأحزاب\",\"سبأ\",\"فاطر\",\"يس\",\"الصافات\",\"ص\",\"الزمر\",\"غافر\",\"فصلت\",\"الشورى\",\"الزخرف\",\"الدخان\",\"الجاثية\",\"الأحقاف\",\"محمد\",\"الفتح\",\"الحجرات\",\"ق\",\"الذاريات\",\"الطور\",\"النجم\",\"القمر\",\"الرحمن\",\"الواقعة\",\"الحديد\",\"المجادلة\",\"الحشر\",\"الممتحنة\",\"الصف\",\"الجمعة\",\"المنافقون\",\"التغابن\",\"الطلاق\",\"التحريم\",\"الملك\",\"القلم\",\"الحاقة\",\"المعارج\",\"نوح\",\"الجن\",\"المزمل\",\"المدثر\",\"القيامة\",\"الإنسان\",\"المرسلات\",\"النبأ\",\"النازعات\",\"عبس\",\"التكوير\",\"الانفطار\",\"المطففين\",\"الانشقاق\",\"البروج\",\"الطارق\",\"الأعلى\",\"الغاشية\",\"الفجر\",\"البلد\",\"الشمس\",\"الليل\",\"الضحى\",\"الشرح\",\"التين\",\"العلق\",\"القدر\",\"البينة\",\"الزلزلة\",\"العاديات\",\"القارعة\",\"التكاثر\",\"العصر\",\"الهمزة\",\"الفيل\",\"قريش\",\"الماعون\",\"الكوثر\",\"الكافرون\",\"النصر\",\"المسد\",\"الإخلاص\",\"الفلق\",\"الناس\"];\n    \n    const myAzkar = [\"سُبْحَانَ اللهِ، وَالْحَمْدُ للهِ، وَلَا إِلَهَ إِلَّا اللهُ، وَاللهُ أَكْبَرُ\", \"لَا إِلَهَ إِلَّا أَنْتَ سُبْحَانَكَ إِنِّي كُنْتُ مِنَ الظَّالِمِينَ\", \"لَا إِلَهَ إِلَّا اللهُ وَحْدَهُ لَا شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ\", \"سُبُّوحٌ، قُدُّوسٌ، رَبُّ الْمَلَائِكَةِ وَالرُّوحِ\", \"اللَّهُمَّ صَلِّ عَلَى سَيِّدِنَا مُحَمَّدٍ\", \"أَسْتَغْفِرُ اللَّهَ الْعَظِيمَ وَأَتوبُ إِلَيْهِ\"];\n\n    const afterPrayerAzkar = [{ text: \"أستغفر الله العظيم الذي لا إله إلا هو الحي القيوم وأتوب إليه\", count: 3 }, { text: \"اللَّهُمَّ أَنْتَ السَّلامُ، ومِنْكَ السَّلامُ، تَبَارَكْتَ يا ذا الجَلالِ والإكْرَامِ\", count: 1 }, { text: \"لا إلهَ إلاَّ اللهُ وحدَه لا شريكَ له، له الملكُ وله الحمدُ وهو على كلِّ شيءٍ قدير، اللهمَّ لا مانعَ لما أعطيتَ، ولا مُعطيَ لما منعتَ، ولا ينفعُ ذا الجدِّ منك الجدُّ\", count: 1 }, { text: \"لا إلهَ إلاَّ اللهُ وحده لا شريك له، له الملكُ وله الحمدُ وهو على كلِّ شيءٍ قدير، لا حولَ ولا قوةَ إلاَّ بالله، لا إلهَ إلاَّ اللهُ ولا نعبدُ إلاَّ إياه، له النعمةُ وله الفضلُ وله الثناءُ الحسن، لا إلهَ إلاَّ اللهُ مخلصين له الدين ولو كره الكافرون\", count: 1 }, { text: \"سبحان الله والحمد لله ولا إلهَ إلاَّ اللهُ والله أكبر\", count: 99 }, { text: \"لا إلهَ إلاَّ اللهُ وحدَه لا شريكَ له، له الملكُ وله الحمدُ وهو على كلِّ شيءٍ قدير\", count: 1 }, { text: \"آية الكرسي: اللَّهُ لَا إِلَهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ لَهُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ مَنْ ذَا الَّذِي يَشْفَعُ عِنْدَهُ إِلَّا بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يُحِيطُونَ بِشَيْءٍ مِنْ عِلْمِهِ إِلَّا بِمَا شَاءَ وَسِعَ كُرْسِيُّهُ السَّمَاوَاتِ وَالْأَرْضَ وَلَا يَئُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ\", count: 1 }, { text: \"سورة الإخلاص: قُلْ هُوَ اللَّهُ أَحَدٌ (1) اللَّهُ الصَّمَدُ (2) لَمْ يَلِدْ وَلَمْ يُولَدْ (3) وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ (4)\", count: 3 }, { text: \"سورة الفلق: قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ (1) مِنْ شَرِّ مَا خَلَقَ (2) وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ (3) وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ (4) وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ (5)\", count: 3 }, { text: \"سورة الناس: قُلْ أَعُوذُ بِرَبِّ النَّاسِ (1) مَلِكِ النَّاسِ (2) إِلَهِ النَّاسِ (3) مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ (4) الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ (5) مِنَ الْجِنَّةِ وَالنَّاسِ (6)\", count: 3 }, { text: \"لا إلهَ إلاَّ اللهُ وحدَه لا شريكَ له، له الملكُ وله الحمدُ يُحيي ويُميتُ وهو على كلِّ شيءٍ قدير\", count: 10 }, { text: \"اللَّهُمَّ إنِّي أَسْأَلُكَ عِلْمًا نَافِعًا، وَرِزْقًا طَيِّبًا، وَعَمَلًا مُتَقَبَّلًا\", count: 1 }, { text: \"اللَّهُمَّ أَجِرْنِي مِنَ النَّارِ\", count: 7 }];\n\n    const morningAzkarData = [{ title: \"الذكر الأول\", text: \"قراءة آية الكرسي: \\\"اللَّهُ لَا إِلَهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ لَهُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ مَنْ ذَا الَّذِي يَشْفَعُ عِنْدَهُ إِلَّا بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يُحِيطُونَ بِشَيْءٍ مِنْ عِلْمِهِ إِلَّا بِمَا شَاءَ وَسِعَ كُرْسِيُّهُ السَّمَاوَاتِ وَالْأَرْضَ وَلَا يَئُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ\\\".\", count: 1 }, { title: \"الذكر الثاني\", text: \"قراءة سورة الإخلاص: \\\"قُلْ هُوَ اللَّهُ أَحَدٌ (1) اللَّهُ الصَّمَدُ (2) لَمْ يَلِدْ وَلَمْ يُولَدْ (3) وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ (4)\\\".\", count: 3 }, { title: \"الذكر الثالث\", text: \"قراءة سورة الفلق: \\\"قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ (1) مِنْ شَرِّ مَا خَلَقَ (2) وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ (3) وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ (4) وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ (5)\\\".\", count: 3 }, { title: \"الذكر الرابع\", text: \"قراءة سورة الناس: \\\"قُلْ أَعُوذُ بِرَبِّ النَّاسِ (1) مَلِكِ النَّاسِ (2) إِلَهِ النَّاسِ (3) مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ (4) الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ (5) مِنَ الْجِنَّةِ وَالنَّاسِ (6)\\\".\", count: 3 }, { title: \"الذكر الخامس\", text: \"\\\"أَصْبَحْنَا وَأَصْبَحَ الْمُلْكُ لِلَّهِ، وَالْحَمْدُ لِلَّهِ، لاَ إِلَهَ إلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ، رَبِّ أَسْأَلُكَ خَيْرَ مَا فِي هَذَا الْيَوْمِ وَخَيْرَ مَا بَعْدَهُ، وَأَعُوذُ بِكَ مِنْ شَرِّ مَا فِي هَذَا الْيَوْمِ وَشرِّ مَا بَعْدَهُ، رَبِّ أَعُوذُ بِكَ مِنَ الْكَسَلِ، وَسُوءِ الْكِبَرِ، رَبِّ أَعُوذُ بِكَ مِنْ عَذَابٍ فِي النَّارِ وَعَذَابٍ فِي الْقَبْرِ\\\".\", count: 1 }, { title: \"الذكر السادس\", text: \"\\\"اللَّهُمَّ أَنْتَ رَبِّي لَا إِلَهَ إِلَّا أَنْتَ، خَلقتَنِي وَأَنَا عَبْدُكَ، وَأَنَا عَلَى عَهْدِكَ وَوَعْدِكَ مَا اسْتَطعتُ، أَعُوذُ بِكَ مِنْ شَرِّ مَا صَنَعْتُ، أَبُوءُ لَكَ بِنِعْمَتِكَ عَلَيَّ، وَأَبُوءُ لَكَ بِذَنْبِي فَاغْفِرْ لِي، فَإِنَّهُ لَا يَغْفِرُ الذُّنُوبَ إِلَّا أَنْتَ\\\".\", count: 1 }, { title: \"الذكر السابع\", text: \"\\\"اللَّهُمَّ إِنِّي أَصْبَحْتُ أُشْهِدُكَ وَأُشْهِدُ حَمَلَةَ عَرْشِكَ، وَمَلَائِكَتَكَ وَجَمِيعَ خَلْقِكَ، أَنَّكَ أَنْتَ اللَّهُ لَا إِلَهَ إِلَّا أَنْتَ وَحْدَكَ لَا شريكَ لَكَ، وَأَنَّ مُحَمَّدًا عَبْدُكَ وَرَسُولُكَ\\\".\", count: 4 }, { title: \"الذكر الثامن\", text: \"\\\"اللَّهُمَّ مَا أَصْبَحَ بِي مِنْ نِعمةٍ أَوْ بِأَحَدٍ مِنْ خَلْقِكَ فَمِنْكَ وَحْدَكَ لَا شَرِيكَ لَكَ، فَلَكَ الْحَمْدُ وَلَكَ الشُّكْرُ\\\".\", count: 1 }, { title: \"الذكر التاسع\", text: \"\\\"اللَّهُمَّ عَافِنِي فِي بَدَنِي، اللَّهُمَّ عَافِنِي فِي سَمْعِي، اللَّهُمَّ عَافِنِي فِي بَصَرِي، لَا إِلَهَ إِلَّا أَنْتَ. اللَّهُمَّ إِنِّي أَعُوذُ بِكَ مِنَ الْكُفْرِ وَالْفَقْرِ، وَأَعُوذُ بِكَ مِنْ عَذَابِ الْقَبْرِ، لَا إِلَهَ إِلَّا أَنْتَ\\\".\", count: 3 }, { title: \"الذكر العاشر\", text: \"\\\"حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ عَلَيْهِ تَوَكَّلْتُ وَهُوَ رَبُّ الْعَرْشِ الْعَظِيمِ\\\".\", count: 7 }, { title: \"الذكر الحادي عشر\", text: \"\\\"اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ وَالْعَافِيَةَ فِي الدُّنْيَا وَالْآخِرَةِ، اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ وَالْعَافِيَةَ: فِي دِينِي وَدُنْيَايَ وَأَهْلِي، وَمَالِي، اللَّهُمَّ اسْتُرْ عَوْرَاتِي، وَآمِنْ رَوْعَاتِي، اللَّهُمَّ احْفَظْنِي مِنْ بَيْنِ يَدَيَّ، وَمِنْ خَلْفِي، وَعَنْ يَمِينِي، وَعَنْ شِمَالِي، وَمِنْ فَوْقِي، وَأَعُوذُ بِعَظَمَتِكَ أَنْ أُغْتَالَ مِنْ تَحْتِي\\\".\", count: 1 }, { title: \"الذكر الثاني عشر\", text: \"\\\"اللَّهُمَّ عَالِمَ الغَيْبِ وَالشَّهَادَةِ فَاطِرَ السَّمَواتِ وَالْأَرْضِ، رَبَّ كُلِّ شَيْءٍ وَمَلِيكَهُ، أَشْهَدُ أَنْ لَا إِلَهَ إِلَّا أَنْتَ، أَعُوذُ بِكَ مِنْ شَرِّ نَفْسِي، وَمِنْ شَرِّ الشَّيْطَانِ وَشِرْكِهِ، وَأَنْ أَقْتَرِفَ عَلَى نَفْسِي سُوءًا، أَوْ أَجُرَّهُ إِلَى مُسْلِمٍ\\\".\", count: 1 }, { title: \"الذكر الثالث عشر\", text: \"\\\"بِسْمِ اللَّهِ الَّذِي لَا يَضُرُّ مَعَ اسْمِهِ شَيْءٌ فِي الْأَرْضِ وَلَا فِي السَّمَاءِ وَهُوَ السَّمِيعُ الْعَلِيمُ\\\".\", count: 3 }, { title: \"الذكر الرابع عشر\", text: \"\\\"رَضِيتُ بِاللَّهِ رَبَّاً، وَبِالْإِسْلَامِ دِيناً، وَبِمُحَمَّدٍ صلى الله عليه وسلم نَبِيّاً\\\".\", count: 3 }, { title: \"الذكر الخامس عشر\", text: \"\\\"يَا حَيُّ يَا قَيُّومُ بِرَحْمَتِكَ أَسْتَغِيثُ أَصْلِحْ لِي شَأْنِي كُلَّهُ وَلَا تَكِلْنِي إِلَى نَفْسِي طَرْفَةَ عَيْنٍ\\\".\", count: 1 }, { title: \"الذكر السادس عشر\", text: \"\\\"أَصْبَحْنَا عَلَى فِطْرَةِ الْإِسْلَامِ وَعَلَى كَلِمَةِ الْإِخْلَاصِ، وَعَلَى دِينِ نَبِيِّنَا مُحَمَّدٍ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، وَعَلَى مِلَّةِ أَبِينَا إِبْرَاهِيمَ حَنِيفًا مُسْلِمًا وَمَا كَانَ مِنَ الْمُشْرِكِينَ\\\".\", count: 1 }, { title: \"الذكر السابع عشر\", text: \"\\\"سُبْحَانَ اللَّهِ وَبِحَمْدِهِ: عَدَدَ خَلْقِهِ، وَرِضَا نَفْسِهِ، وَزِنَةَ عَرْشِهِ، وَمِدَادَ كَلِمَاتِهِ\\\".\", count: 3 }, { title: \"الذكر الثامن عشر\", text: \"\\\"سُبْحَانَ اللَّهِ وَبِحَمْدِهِ\\\".\", count: 100 }, { title: \"الذكر التاسع عشر\", text: \"\\\"لَا إِلَهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ، وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ\\\".\", count: 100 }, { title: \"الذكر العشرون\", text: \"\\\"أَسْتَغْفِرُ اللَّهَ وَأَتُوبُ إِلَيْهِ\\\".\", count: 100 }, { title: \"الذكر الحادي والعشرون\", text: \"\\\"اللَّهُمَّ صَلِّ وَسَلِّمْ عَلَى نَبِيِّنَا مُحَمَّدٍ\\\".\", count: 10 }];\n\n    const eveningAzkarData = [{ title: \"الذكر الأول\", text: \"آية الكرسي: \\\"اللَّهُ لَا إِلَهَ إِلَّا هُوَ الْحَيُّ الْقَيُّومُ لَا تَأْخُذُهُ سِنَةٌ وَلَا نَوْمٌ لَهُ مَا فِي السَّمَاوَاتِ وَمَا فِي الْأَرْضِ مَنْ ذَا الَّذِي يَشْفَعُ عِنْدَهُ إِلَّا بِإِذْنِهِ يَعْلَمُ مَا بَيْنَ أَيْدِيهِمْ وَمَا خَلْفَهُمْ وَلَا يُحِيطُونَ بِشَيْءٍ مِنْ عِلْمِهِ إِلَّا بِمَا شَاءَ وَسِعَ كُرْسِيُّهُ السَّمَاوَاتِ وَالْأَرْضَ وَلَا يَئُودُهُ حِفْظُهُمَا وَهُوَ الْعَلِيُّ الْعَظِيمُ\\\".\", count: 1 }, { title: \"الذكر الثاني\", text: \"سورة الإخلاص: \\\"قُلْ هُوَ اللَّهُ أَحَدٌ (1) اللَّهُ الصَّمَدُ (2) لَمْ يَلِدْ وَلَمْ يُولَدْ (3) وَلَمْ يَكُنْ لَهُ كُفُوًا أَحَدٌ (4)\\\".\", count: 3 }, { title: \"الذكر الثالث\", text: \"سورة الفلق: \\\"قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ (1) مِنْ شَرِّ مَا خَلَقَ (2) وَمِنْ شَرِّ غَاسِقٍ إِذَا وَقَبَ (3) وَمِنْ شَرِّ النَّفَّاثَاتِ فِي الْعُقَدِ (4) وَمِنْ شَرِّ حَاسِدٍ إِذَا حَسَدَ (5)\\\".\", count: 3 }, { title: \"الذكر الرابع\", text: \"سورة الناس: \\\"قُلْ أَعُوذُ بِرَبِّ النَّاسِ (1) مَلِكِ النَّاسِ (2) إِلَهِ النَّاسِ (3) مِنْ شَرِّ الْوَسْوَاسِ الْخَنَّاسِ (4) الَّذِي يُوَسْوِسُ فِي صُدُورِ النَّاسِ (5) مِنَ الْجِنَّةِ وَالنَّاسِ (6)\\\".\", count: 3 }, { title: \"الذكر الخامس\", text: \"خواتيم سورة البقرة: \\\"آمَنَ الرَّسُولُ بِمَا أُنزِلَ إِلَيْهِ مِن رَّبِّهِ وَالْمُؤْمِنُونَ كُلٌّ آمَنَ بِاللَّهِ وَمَلائِكَتِهِ وَكُتُبِهِ وَرُسُلِهِ لاَ نُفَرِّقُ بَيْنَ أَحَدٍ مِّن رُّسُلِهِ وَقَالُواْ سَمِعْنَا وَأَطَعْنَا غُفْرَانَكَ رَبَّنَا وَإِلَيْكَ الْمَصِيرُ (285) لاَ يُكَلِّفُ اللَّهُ نَفْسًا إِلاَّ وُسْعَهَا لَهَا مَا كَسَبَتْ وَعَلَيْهَا مَا اكْتَسَبَتْ رَبَّنَا لاَ تُؤَاخِذْنَا إِن نَّسِينَا أَوْ أَخْطَأْنَا رَبَّنَا وَلاَ تَحْمِلْ عَلَيْنَا إِصْرًا كَمَا حَمَلْتَهُ عَلَى الَّذِينَ مِن قَبْلِنَا رَبَّنَا وَلاَ تُحَمِّلْنَا مَا لاَ طَاقَةَ لَنَا بِهِ وَاعْفُ عَنَّا وَاغْفِرْ لَنَا وَارْحَمْنَا أَنتَ مَوْلانَا فَانصُرْنَا عَلَى الْقَوْمِ الْكَافِرِينَ (286)\\\".\", count: 1 }, { title: \"الذكر السادس\", text: \"\\\"أَمْسَيْنَا وَأَمْسَى الْمُلْكُ لِلَّهِ، وَالْحَمْدُ لِلَّهِ، لاَ إِلَهَ إلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ، رَبِّ أَسْأَلُكَ خَيْرَ مَا فِي هَذِهِ اللَّيْلَةِ وَخَيْرَ مَا بَعْدَهَا، وَأَعُوذُ بِكَ مِنْ شَرِّ مَا فِي هَذِهِ اللَّيْلَةِ وَشَرِّ مَا بَعْدَهَا، رَبِّ أَعُوذُ بِكَ مِنَ الْكَسَلِ، وَسُوءِ الْكِبَرِ، رَبِّ أَعُوذُ بِكَ مِنْ عَذَابٍ فِي النَّارِ وَعَذَابٍ فِي الْقَبْرِ\\\".\", count: 1 }, { title: \"الذكر السابع\", text: \"\\\"اللَّهُمَّ بِكَ أَمْسَيْنَا، وَبِكَ أَصْبَحْنَا، وَبِكَ نَحْيَا، وَبِكَ نَمُوتُ، وَإِلَيْكَ الْمَصِيرُ\\\".\", count: 1 }, { title: \"الذكر الثامن\", text: \"\\\"اللَّهُمَّ أَنْتَ رَبِّي لَا إِلَهَ إِلَّا أنتَ، خَلقتَنِي وَأَنَا عَبْدُكَ، وَأَنَا عَلَى عَهْدِكَ وَوَعْدِكَ مَا اسْتَطعتُ، أَعُوذُ بِكَ مِنْ شَرِّ مَا صَنَعْتُ، أَبُوءُ لَكَ بِنِعْمَتِكَ عَلَيَّ، وَأَبُوءُ لَكَ بِذَنْبِي فَاغْفِرْ لِي، فَإِنَّهُ لَا يَغْفِرُ الذُّنُوبَ إِلَّا أَنْتَ\\\".\", count: 1 }, { title: \"الذكر التاسع\", text: \"\\\"اللَّهُمَّ مَا أَمْسَى بِي مِنْ نِعمةٍ أَوْ بِأَحَدٍ مِنْ خَلْقِكَ فَمِنْكَ وَحْدَكَ لَا شَرِيكَ لَكَ، فَلَكَ الْحَمْدُ وَلَكَ الشُّكْرُ\\\".\", count: 1 }, { title: \"الذكر العاشر\", text: \"\\\"اللَّهُمَّ إِنِّي أَمْسَيْتُ أُشْهِدُكَ وَأُشْهِدُ حَمَلَةَ عَرْشِكَ، وَمَلَائِكَتَكَ وَجَمِيعَ خَلْقِكَ، أَنَّكَ أَنْتَ اللَّهُ لَا إِلَهَ إِلَّا أَنْتَ وَحْدَكَ لَا شَرِيكَ لَكَ، وَأَنَّ مُحَمَّدًا عَبْدُكَ وَرَسُولُكَ\\\".\", count: 4 }, { title: \"الذكر الحادي عشر\", text: \"\\\"بِسْمِ اللَّهِ الَّذِي لَا يَضُرُّ مَعَ اسْمِهِ شَيْءٌ فِي الْأَرْضِ وَلَا فِي السَّمَاءِ وَهُوَ السَّمِيعُ الْعَلِيمُ\\\".\", count: 3 }, { title: \"الذكر الثاني عشر\", text: \"أعوذ بكلمات الله التامات من شر ما خلق.\", count: 3 }, { title: \"الذكر الثالث عشر\", text: \"\\\"حَسْبِيَ اللَّهُ لَا إِلَهَ إِلَّا هُوَ عَلَيْهِ تَوَكَّلْتُ وَهُوَ رَبُّ الْعَرْشِ الْعَظِيمِ\\\".\", count: 7 }, { title: \"الذكر الرابع عشر\", text: \"\\\"اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ وَالْعَافِيَةَ فِي الدُّنْيَا وَالْآخِرَةِ، اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَفْوَ وَالْعَافِيَةَ: فِي دِينِي وَدُنْيَايَ وَأَهْلِي، وَمَالِي، اللَّهُمَّ اسْتُرْ عَوْرَاتِي، وَآمِنْ رَوْعَاتِي، اللَّهُمَّ احْفَظْنِي مِنْ بَيْنِ يَدَيَّ، وَمِنْ خَلْفِي، وَعَنْ يَمِينِي، وَعَنْ شِمَالِي، وَمِنْ فَوْقِي، وَأَعُوذُ بِعَظَمَتِكَ أَنْ أُغْتَالَ مِنْ تَحْتِي\\\".\", count: 1 }, { title: \"الذكر الخامس عشر\", text: \"\\\"اللَّهُمَّ عَالِمَ الغَيْبِ وَالشَّهَادَةِ فَاطِرَ السَّمَوَاتِ وَالْأَرْضِ، رَبَّ كُلِّ شَيْءٍ وَمَلِيكَهُ، أَشْهَدُ أَنْ لَا إِلَهَ إِلَّا أَنْتَ، أَعُوذُ بِكَ مِنْ شَرِّ نَفْسِي، وَمِنْ شَرِّ الشَّيْطَانِ وَشِرْكِهِ، وَأَنْ أَقْتَرِفَ عَلَى نَفْسِي سُوءًا، أَوْ أَجُرَّهُ إِلَى مُسْلِمٍ\\\".\", count: 1 }, { title: \"الذكر السادس عشر\", text: \"\\\"رَضِيتُ بِاللَّهِ رَبَّاً، وَبِالْإِسْلَامِ دِيناً، وَبِمُحَمَّدٍ صلى الله عليه وسلم نَبِيّاً\\\".\", count: 3 }, { title: \"الذكر السابع عشر\", text: \"\\\"يَا حَيُّ يَا قَيُّومُ بِرَحْمَتِكَ أَسْتَغِيثُ أَصْلِحْ لِي شَأْنِي كُلَّهُ وَلَا تَكِلْنِي إِلَى نَفْسِي طَرْفَةَ عَيْنٍ\\\".\", count: 1 }, { title: \"الذكر التاسع عشر\", text: \"\\\"أَمْسَيْنَا عَلَى فِطْرَةِ الْإِسْلَامِ وَعَلَى كَلِمَةِ الْإِخْلَاصِ، وَعَلَى دِينِ نَبِيِّنَا مُحَمَّدٍ صَلَّى اللَّهُ عَلَيْهِ وَسَلَّمَ، وَعَلَى مِلَّةِ أَبِينَا إِبْرَاهِيمَ حَنِيفًا مُسْلِمًا وَمَا كَانَ مِنَ الْمُشْرِكِينَ\\\".\", count: 1 }, { title: \"التسبيح\", text: \"\\\"لَا إِلَهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ، لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ، وَهُوَ عَلَى كُلِّ شَيْءٍ قَدِيرٌ\\\".\", count: 100 }, { title: \"التسبيح\", text: \"\\\"سبحان الله وبحمده سبحان الله العظيم\\\".\", count: 100 }, { title: \"الاستغفار\", text: \"\\\"استغفر الله العظيم الذي لا إله إلا هو الحي القيوم واتوب اليه\\\".\", count: 100 }, { title: \"الصلاة على النبي\", text: \"\\\"اللهم صلي وسلم وبارك على سيدنا محمد صلاة دائمة بدوام ملك الله\\\".\", count: 10 }];\n\n    let currentSuraIndex = -1;\n    let isRepeat = false;\n\n    function toggleNightMode() {\n        document.body.classList.toggle('night-mode');\n        document.getElementById('modeIcon').className = document.body.classList.contains('night-mode') ? 'fas fa-sun' : 'fas fa-moon';\n    }\n\n    function buildQuran() {\n        const container = document.getElementById('suraIndex');\n        suras.forEach((name, i) => {\n            const card = document.createElement('div');\n            card.className = 'sura-card';\n            card.id = `sura-${i}`;\n            card.setAttribute('data-name', name);\n            card.innerHTML = `<span>${i+1}. ${name}</span> <i class=\"fas fa-play\" style=\"font-size:12px; color:var(--gold)\"></i>`;\n            card.onclick = () => playSura(i);\n            container.appendChild(card);\n        });\n    }\n\n    function buildAzkar() {\n        const container = document.getElementById('azkarList');\n        container.innerHTML = \"\"; \n        myAzkar.forEach((text, i) => {\n            const id = `zikr-${i}`;\n            const card = document.createElement('div');\n            card.className = 'daily-card';\n            card.style.cursor = \"pointer\";\n            card.onclick = () => incrementAnyCounter(id, 100);\n            card.innerHTML = `<p class=\"ruqya-text\" style=\"font-weight:bold; margin-bottom:10px;\">${text}</p><div class=\"progress-bar-container\"><div id=\"bar-${id}\" class=\"progress-bar-fill\"></div></div><div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"count-${id}\">0</span> / 100</span><i class=\"fas fa-sync-alt\" style=\"cursor:pointer; color: #ff4444; font-size: 13px;\" onclick=\"event.stopPropagation(); resetAnyCounter('${id}')\"> تصفير</i></div>`;\n            container.appendChild(card);\n        });\n    }\n\n    function buildAfterPrayer() {\n        const container = document.getElementById('afterPrayerList');\n        container.innerHTML = \"\"; \n        afterPrayerAzkar.forEach((item, i) => {\n            const id = `after-${i}`;\n            const card = document.createElement('div');\n            card.className = 'daily-card';\n            card.style.cursor = \"pointer\";\n            card.onclick = () => incrementAnyCounter(id, item.count);\n            card.innerHTML = `<p class=\"ruqya-text\" style=\"font-weight:bold; margin-bottom:10px;\">${item.text}</p><div class=\"progress-bar-container\"><div id=\"bar-${id}\" class=\"progress-bar-fill\"></div></div><div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"count-${id}\">0</span> / ${item.count}</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer; color: #ff4444; font-size: 13px;\" onclick=\"event.stopPropagation(); resetAnyCounter('${id}')\"> تصفير</i></div>`;\n            container.appendChild(card);\n        });\n    }\n\n    function buildMorningAzkar() {\n        const container = document.getElementById('morningAzkarList');\n        container.innerHTML = \"\"; \n        morningAzkarData.forEach((item, i) => {\n            const id = `morning-${i}`;\n            const card = document.createElement('div');\n            card.className = 'daily-card';\n            card.style.cursor = \"pointer\";\n            card.onclick = () => incrementAnyCounter(id, item.count);\n            card.innerHTML = `<h3 style=\"margin-bottom:10px;\"><i class=\"fas fa-sun\"></i> ${item.title}</h3><p class=\"ruqya-text\" style=\"font-weight:bold; margin-bottom:10px;\">${item.text}</p><div class=\"progress-bar-container\"><div id=\"bar-${id}\" class=\"progress-bar-fill\"></div></div><div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"count-${id}\">0</span> / ${item.count}</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer; color: #ff4444; font-size: 13px;\" onclick=\"event.stopPropagation(); resetAnyCounter('${id}')\"> تصفير</i></div>`;\n            container.appendChild(card);\n        });\n    }\n\n    function buildEveningAzkar() {\n        const container = document.getElementById('eveningAzkarList');\n        container.innerHTML = \"\"; \n        eveningAzkarData.forEach((item, i) => {\n            const id = `evening-${i}`;\n            const card = document.createElement('div');\n            card.className = 'daily-card';\n            card.style.cursor = \"pointer\";\n            card.onclick = () => incrementAnyCounter(id, item.count);\n            card.innerHTML = `<h3 style=\"margin-bottom:10px;\"><i class=\"fas fa-moon\"></i> ${item.title}</h3><p class=\"ruqya-text\" style=\"font-weight:bold; margin-bottom:10px;\">${item.text}</p><div class=\"progress-bar-container\"><div id=\"bar-${id}\" class=\"progress-bar-fill\"></div></div><div class=\"counter-area\"><span style=\"color:var(--gold)\">التكرار: <span id=\"count-${id}\">0</span> / ${item.count}</span><i class=\"fas fa-undo-alt\" style=\"cursor:pointer; color: #ff4444; font-size: 13px;\" onclick=\"event.stopPropagation(); resetAnyCounter('${id}')\"> تصفير</i></div>`;\n            container.appendChild(card);\n        });\n    }\n\n    function incrementAnyCounter(id, max) {\n        const countElem = document.getElementById(`count-${id}`);\n        const barElem = document.getElementById(`bar-${id}`);\n        if(!countElem || !barElem) return;\n        let count = parseInt(countElem.innerText);\n        if (count < max) {\n            count++;\n            countElem.innerText = count;\n            barElem.style.width = (count / max * 100) + \"%\";\n            if ('vibrate' in navigator) navigator.vibrate(40);\n        }\n    }\n\n    function resetAnyCounter(id) {\n        document.getElementById(`count-${id}`).innerText = \"0\";\n        document.getElementById(`bar-${id}`).style.width = \"0%\";\n    }\n\n    function resetAllCountersInScreen(containerId) {\n        const container = document.getElementById(containerId);\n        const counters = container.querySelectorAll('[id^=\"count-\"]');\n        const bars = container.querySelectorAll('[id^=\"bar-\"]');\n        counters.forEach(c => c.innerText = \"0\");\n        bars.forEach(b => b.style.width = \"0%\");\n        if ('vibrate' in navigator) navigator.vibrate([50, 30, 50]);\n    }\n\n    function playSura(index) {\n        if (index < 0) index = suras.length - 1;\n        if (index >= suras.length) index = 0;\n        currentSuraIndex = index;\n        const num = (index + 1).toString().padStart(3, '0');\n        const audio = document.getElementById('mainAudio');\n        document.getElementById('audioSrc').src = `https://server10.mp3quran.net/minsh/${num}.mp3`;\n        document.getElementById('nowPlaying').innerText = \"سورة \" + suras[index];\n        document.querySelectorAll('.sura-card').forEach(c => c.classList.remove('playing'));\n        document.getElementById(`sura-${index}`).classList.add('playing');\n        audio.load(); audio.play();\n    }\n\n    document.getElementById('mainAudio').onended = () => isRepeat ? playSura(currentSuraIndex) : playNext();\n    function playNext() { playSura(currentSuraIndex + 1); }\n    function playPrev() { playSura(currentSuraIndex - 1); }\n    function toggleRepeat() { isRepeat = !isRepeat; document.getElementById('repeatBtn').classList.toggle('active', isRepeat); }\n\n    function filterSuras() {\n        const val = document.getElementById('suraSearch').value;\n        document.querySelectorAll('.sura-card').forEach(card => {\n            card.style.display = card.getAttribute('data-name').includes(val) ? 'flex' : 'none';\n        });\n    }\n\n    function updateCounter(id, max) {\n        const counterElem = document.getElementById(id);\n        let currentCount = parseInt(counterElem.innerText);\n        if (currentCount < max) {\n            currentCount++;\n            counterElem.innerText = currentCount;\n            if ('vibrate' in navigator) navigator.vibrate(40);\n        }\n    }\n\n    function resetCounter(id) { document.getElementById(id).innerText = \"0\"; }\n\n    function formatTime12(time) {\n        let [hours, minutes] = time.split(':');\n        hours = parseInt(hours);\n        const ampm = hours >= 12 ? 'م' : 'ص';\n        hours = hours % 12 || 12;\n        return `${hours}:${minutes} ${ampm}`;\n    }\n\n    async function loadPrayers() {\n        const cities = [{ name: \"القاهرة\", city: \"Cairo\", country: \"Egypt\" }, { name: \"مكة المكرمة\", city: \"Makkah\", country: \"Saudi Arabia\" }];\n        let htmlContent = \"\";\n        for (let loc of cities) {\n            try {\n                const res = await fetch(`https://api.aladhan.com/v1/timingsByCity?city=${loc.city}&country=${loc.country}&method=4`);\n                const data = await res.json();\n                const t = data.data.timings;\n                htmlContent += `<div class=\"prayer-grid\"><div class=\"city-title\"><i class=\"fas fa-location-dot\"></i> مواقيت ${loc.name}</div><div class=\"prayer-item\"><span class=\"prayer-name\">الفجر</span><span class=\"prayer-time\">${formatTime12(t.Fajr)}</span></div><div class=\"prayer-item\"><span class=\"prayer-name\">الظهر</span><span class=\"prayer-time\">${formatTime12(t.Dhuhr)}</span></div><div class=\"prayer-item\"><span class=\"prayer-name\">العصر</span><span class=\"prayer-time\">${formatTime12(t.Asr)}</span></div><div class=\"prayer-item\"><span class=\"prayer-name\">المغرب</span><span class=\"prayer-time\">${formatTime12(t.Maghrib)}</span></div><div class=\"prayer-item\" style=\"grid-column: span 2;\"><span class=\"prayer-name\">العشاء</span><span class=\"prayer-time\">${formatTime12(t.Isha)}</span></div></div>`;\n            } catch(e) { htmlContent += `<p style=\"text-align:center;\">خطأ في التحميل</p>`; }\n        }\n        document.getElementById('prayerData').innerHTML = htmlContent;\n    }\n\n    async function initApp() {\n        const today = new Date();\n        document.getElementById('gregorian').innerText = today.toLocaleDateString('ar-EG');\n\n        // --- إضافة ميزة حديث اليوم المتغير تلقائياً ---\n        const dailyHadiths = [\n            \"قال ﷺ: 'خياركم من تعلم القرآن وعلمه'\",\n            \"قال ﷺ: 'من سلك طريقًا يلتمس فيه علمًا سهل الله له به طريقًا إلى الجنة'\",\n            \"قال ﷺ: 'كلمتان خفيفتان على اللسان، ثقيلتان في الميزان: سبحان الله وبحمده، سبحان الله العظيم'\",\n            \"قال ﷺ: 'أحب الأعمال إلى الله أدومها وإن قل'\",\n            \"قال ﷺ: 'الدين النصيحة'\",\n            \"قال ﷺ: 'اتق الله حيثما كنت، وأتبع السيئة الحسنة تمحها'\",\n            \"قال ﷺ: 'إنما الأعمال بالنيات وإنما لكل امرئ ما نوى'\",\n            \"قال ﷺ: 'تبسمك في وجه أخيك لك صدقة'\",\n            \"قال ﷺ: 'لا يؤمن أحدكم حتى يحب لأخيه ما يحب لنفسه'\"\n        ];\n        // حساب اليوم في السنة لاختيار حديث مختلف يومياً\n        const dayOfYear = Math.floor((today - new Date(today.getFullYear(), 0, 0)) / (1000 * 60 * 60 * 24));\n        const hadithIndex = dayOfYear % dailyHadiths.length;\n        document.getElementById('hadith').innerText = dailyHadiths[hadithIndex];\n        // ---------------------------------------------\n\n        try {\n            const resH = await fetch(`https://api.aladhan.com/v1/gToH?date=${String(today.getDate()).padStart(2,'0')}-${String(today.getMonth()+1).padStart(2,'0')}-${today.getFullYear()}`);\n            const dataH = await resH.json();\n            document.getElementById('hijri').innerText = `${dataH.data.hijri.day} ${dataH.data.hijri.month.ar} ${dataH.data.hijri.year}`;\n            const resA = await fetch('https://api.alquran.cloud/v1/ayah/' + (Math.floor(Math.random()*6236)+1) + '/ar.alafasy');\n            const dataA = await resA.json();\n            document.getElementById('ayah').innerText = `\"${dataA.data.text}\" [${dataA.data.surah.name}]`;\n        } catch(e) { console.log(\"Init Error\"); }\n    }\n\n    async function loadNames() {\n        const res = await fetch('https://api.aladhan.com/v1/asmaAlHusna');\n        const data = await res.json();\n        document.getElementById('namesData').innerHTML = data.data.map(n => `<div style=\"background:rgba(0,0,0,0.2); padding:10px; border-radius:10px; text-align:center; font-size:13px; border:1px solid var(--gold)\">${n.name}</div>`).join('');\n    }\n\n    function openScreen(id) {\n        document.querySelectorAll('.content-screen').forEach(s => s.classList.remove('active'));\n        document.getElementById(id).classList.add('active');\n        if(id === 'prayerScreen') loadPrayers();\n        if(id === 'namesScreen') loadNames();\n        if(id === 'sebhaScreen') buildAzkar();\n        if(id === 'afterPrayerScreen') buildAfterPrayer();\n        if(id === 'morningAzkarScreen') buildMorningAzkar();\n        if(id === 'eveningAzkarScreen') buildEveningAzkar();\n    }\n    function goHome() { openScreen('homeScreen'); }\n\n    buildQuran();\n    initApp();\n</script>\n</body>\n</html>"}]